{
  "name": "rimelight-cli",
  "version": "1.0.0",
  "private": true,
  "description": "A CLI utility for configuration synchronization across multiple projects.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rimelight-Entertainment/rimelight-cli.git"
  },
  "bin": {
    "rimelight": "./bin/cli.ts"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "oxlint -c ./oxlint.config.ts .",
    "lint:fix": "oxlint -c ./oxlint.config.ts . --fix",
    "format": "oxfmt -c ./.oxfmtrc.jsonc . --check",
    "format:fix": "oxfmt -c ./.oxfmtrc.jsonc .",
    "fix": "oxlint -c ./oxlint.config.ts . --fix && oxfmt -c ./.oxfmtrc.jsonc .",
    "check": "oxlint -c ./oxlint.config.ts . && oxfmt -c ./.oxfmtrc.jsonc . --check",
    "sync": "bun bin/cli.ts sync"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/node": "latest",
    "bun-types": "^1.3.10",
    "citty": "^0.1.6",
    "husky": "^9.1.7",
    "oxfmt": "latest",
    "oxlint": "^1.50.0"
  }
}
